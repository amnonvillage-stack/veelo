# Veelo backend — environment variables
# Copy this file to `.env` (same directory) and fill in real values.
# Never commit `.env`.

# Google Gemini API key — required.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Override the image-generation model (optional).
# The server auto-resolves from a preferred list; set this to pin a specific name.
# Run this to see what's available on your key:
#   python3 -c "from google import genai,os; c=genai.Client(api_key=os.environ['GEMINI_API_KEY']); [print(m.name) for m in c.models.list() if 'image' in m.name.lower()]"
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Admin key — required to use catalog write endpoints (POST/DELETE /catalog/products).
# Set to any strong random string. Example: openssl rand -hex 32
ADMIN_KEY=change_me_to_a_strong_random_string

# Comma-separated allowed frontend origins for CORS.
# In production, set to your actual domain(s).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Set to "true" to expose internal error details in API responses (dev only).
DEBUG=false

# For testing the WhatsApp inquiry preview on a real device:
# Use a tunnel: `cloudflared tunnel --url http://localhost:8000`
PUBLIC_BASE_URL=http://localhost:8000
