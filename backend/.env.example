# Veelo backend — environment variables
# Copy this file to `.env` (same directory) and fill in real values.
# Never commit `.env`.

# Google Gemini API key — required.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# ── Inquiry email — optional but required if you want emails to actually send ──
# /inquiry will write inquiry.eml to disk regardless. To deliver it, configure
# ONE of the two transports below. If neither is set, the email is saved as a
# .eml file you can open manually in Mail.app and re-send.
#
# Where the founder gets the inquiry. Customer is auto-CC'd.
VEELO_INQUIRY_TO=amnonvillage@gmail.com
#
# ── Option A: Resend (recommended for prod) ────────────────────────────────────
# Sign up free at https://resend.com (100 emails/day free tier).
# Verify a sending domain, then use that domain in RESEND_FROM.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM=Veelo <hello@yourdomain.com>
#
# ── Option B: SMTP (Gmail with app password is the quickest) ───────────────────
# 1. https://myaccount.google.com/security → 2-Step Verification → App passwords
# 2. Generate a 16-char app password for "Mail"
# 3. Fill in below. SMTP_USER must be the Gmail address; SMTP_PASS is the app pw.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=your_16_char_app_password
# SMTP_FROM=Veelo <youraccount@gmail.com>
