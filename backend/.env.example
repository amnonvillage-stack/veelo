# Veelo backend — environment variables
# Copy this file to `.env` (same directory) and fill in real values.
# Never commit `.env`.

# Google Gemini API key — required.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# ── Inquiry handoff (WhatsApp Click-to-Chat) ─────────────────────────────────
# Veelo uses WhatsApp instead of email for customer-founder communication.
# The Israeli market lives on WhatsApp; email delivery is unreliable without a
# verified sending domain. When the user taps "Send inquiry", the frontend
# POSTs to /inquiry, the backend persists everything to disk, and the response
# includes a wa.me URL the frontend immediately opens — pre-filled with a
# Hebrew summary plus a link back to /i/{inquiry_id} where the founder sees
# the full simulation.

# Israeli mobile in international format, no leading + or zeros.
# 0523770639 → 972523770639
VEELO_WHATSAPP_PHONE=972523770639

# Public origin where /i/{id} is reachable. The WhatsApp message embeds
# {PUBLIC_BASE_URL}/i/{id} as a clickable link AND WhatsApp fetches this
# URL server-side to build a chat preview card (Open Graph unfurl with
# a thumbnail of the curtain simulation).
#
# Localhost is unreachable for both:
#   • Founder taps the link from their phone → DNS fails.
#   • WhatsApp's crawler can't fetch og:image → no preview thumbnail in chat.
#
# Dev workflow when you want to test the WhatsApp preview end-to-end:
#   $ cloudflared tunnel --url http://localhost:8000
#   → copy the printed https://<random>.trycloudflare.com URL
#   → set PUBLIC_BASE_URL to it, then restart the backend
# (`ngrok http 8000` works the same way.)
#
# Dev without a tunnel: leave as localhost — inquiries still persist and you
# can open /i/{id} in your laptop browser; only the chat preview is missing.
#
# Prod: set to https://veelo.app (or wherever you deploy).
PUBLIC_BASE_URL=http://localhost:8000
